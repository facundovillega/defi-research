WITH p4_01 AS (
    SELECT
        spell_address,
        ts_propose,
        ts_lift,
        hours_coordination,
        mkr_movilizado,
        n_lock_events
    FROM query_7485826
),

p4_02 AS (
    SELECT
        spell_address,
        total_mkr,
        n_voters,
        hhi,
        top1_share_pct
    FROM query_7486415
),

master AS (
    SELECT
        a.spell_address,
        a.ts_propose,
        a.ts_lift,
        a.hours_coordination,
        a.mkr_movilizado,
        a.n_lock_events,
        b.total_mkr,
        b.n_voters,
        b.hhi,
        b.top1_share_pct,
        CASE
            WHEN a.mkr_movilizado = 0 THEN 'no_activity'
            WHEN b.hhi >= 7500 THEN 'high_concentration'
            WHEN b.hhi >= 2500 THEN 'moderate_concentration'
            ELSE 'competitive'
        END AS concentration_regime,
        CASE
            WHEN b.total_mkr < 1 THEN 'micro'
            WHEN b.total_mkr < 100 THEN 'small'
            WHEN b.total_mkr < 10000 THEN 'medium'
            ELSE 'large'
        END AS participation_tier
    FROM p4_01 a
    JOIN p4_02 b ON a.spell_address = b.spell_address
)

SELECT
    spell_address,
    ts_propose,
    ts_lift,
    hours_coordination,
    mkr_movilizado,
    n_lock_events,
    total_mkr,
    n_voters,
    hhi,
    top1_share_pct,
    concentration_regime,
    participation_tier
FROM master
ORDER BY ts_propose
